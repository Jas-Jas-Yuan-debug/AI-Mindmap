{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "outDir": "dist-electron/main",
    "rootDir": "src/main",
    "types": ["node"]
  },
  "include": ["src/main/**/*"],
  "exclude": ["node_modules", "src/renderer", "src/platform", "src/shared"]
}
