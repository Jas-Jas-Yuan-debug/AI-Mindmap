{
  "name": "ai-mindmap",
  "version": "0.1.0",
  "description": "AI-augmented infinite whiteboard. Electron + Web. Obsidian Canvas-compatible.",
  "main": "dist-electron/main/main.js",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:electron": "node scripts/dev-electron.mjs",
    "dev:web": "vite --config vite.config.web.ts",
    "build:electron:renderer": "vite build --config vite.config.electron.ts",
    "build:electron:main": "tsc -p tsconfig.main.json && node scripts/write-main-cjs-marker.mjs",
    "build:electron": "npm run build:electron:renderer && npm run build:electron:main",
    "build:web": "vite build --config vite.config.web.ts",
    "preview:web": "vite preview --config vite.config.web.ts",
    "start": "electron .",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.main.json",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"scripts/**/*.mjs\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,html}\" \"*.{json,md}\"",
    "test": "vitest run",
    "verify:web-no-electron": "node scripts/verify-web-no-electron.mjs"
  },
  "author": "Jason Zhu",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "konva": "^9.3.16",
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-konva": "^18.2.10",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^42.2.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.3",
    "eslint-plugin-react-hooks": "^5.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
